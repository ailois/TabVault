{
  "name": "tabvault",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI bookmark browser extension MVP",
  "manifest": {
    "permissions": [
      "storage",
      "activeTab",
      "scripting",
      "sidePanel",
      "bookmarks"
    ],
    "host_permissions": [
      "https://api.openai.com/*",
      "https://api.anthropic.com/*",
      "https://generativelanguage.googleapis.com/*"
    ]
  },
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tabvault": "file:../.."
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "plasmo": "^0.90.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
