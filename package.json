{
  "name": "tabvault",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI bookmark browser extension MVP",
  "manifest": {
    "permissions": [
      "storage",
      "activeTab",
      "scripting",
      "sidePanel",
      "bookmarks"
    ]
  },
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^26.1.0",
    "plasmo": "^0.90.5",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
